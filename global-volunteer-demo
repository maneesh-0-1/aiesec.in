<!-- 🔥 STEP 1: SORT DATA BEFORE RENDER -->
<script>
(function () {
  const originalFetch = window.fetch;

  window.fetch = async function (...args) {
    const response = await originalFetch(...args);

    try {
      const cloned = response.clone();
      const data = await cloned.json();

      if (data && data.local_committees) {
        data.local_committees.sort((a, b) =>
          a.name.localeCompare(b.name)
        );

        return new Response(JSON.stringify(data), {
          status: response.status,
          statusText: response.statusText,
          headers: response.headers
        });
      }
    } catch (e) {}

    return response;
  };
})();
</script>

<script>
const getTargetElement = () => {
  return document.getElementById('embeddable-auth-container');
};

const customizeFormForProgramme = (targetElement, programmeCode) => {
  const codeToClass = {
    7: 'gv',
    8: 'gta',
    9: 'gte',
  };
  targetElement.classList.add(codeToClass[programmeCode]);
};

const getProgrammeCodeText = (targetElement) => {
  return targetElement.parentElement.parentElement
    .getElementsByClassName('embeddable-auth-programme-code')[0]
    .textContent;
};

const showAiesecAuth = () => {
  const targetElement = getTargetElement();
  const programmeCode = parseInt(getProgrammeCodeText(targetElement) || 7, 10);

  customizeFormForProgramme(targetElement, programmeCode);

  new EmbeddableAuth({
    target: targetElement,
    props: {
      options: {
        registerButtonText: 'Get Started',
        loginButtonText: 'Login',
        registerFormTitle: false,
        afterLoginRedirectTo: '',
        title: false,
        showLogin: false,
        useModalLayout: false,
        disableFormToggle: true,
        allowPhoneCommunication: true,
        profileAttributes: {
          selected_programmes: [programmeCode],
        },
      },
      token: 'e8f212e937b3ad94da3901c93172b95a19b118e749d1234b4466e120b58bfbaadb2e4a9ff9eae08e9199f0f9b07b9541ea21216baa817d353ec7d846e25b1473',
      api: 'production'
    }
  });
};
</script>

