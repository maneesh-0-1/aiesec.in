<!-- 🔥 STEP 2: SORT EVERY TIME DROPDOWN OPENS -->
<script>
document.addEventListener("click", function (e) {

  // detect click near LC field
  if (e.target.closest('#embeddable-auth-container')) {

    setTimeout(() => {
      const items = document.querySelectorAll('#embeddable-auth-container .listItem');

      if (!items || items.length <= 5) return;

      const parent = items[0].parentElement;

      const sorted = Array.from(items).sort((a, b) =>
        a.textContent.trim().localeCompare(b.textContent.trim())
      );

      sorted.forEach(item => parent.appendChild(item));
    }, 150); // wait for dropdown render

